cd web && pnpm exec lint-staged
cd ..

source venv/bin/activate
pre-commit run

# If pre-commit modified files, stage and re-commit with same message
if ! git diff --quiet; then
    echo "\n\nPre-commit modified files. Staging and re-committing..."
    git add -A
    git commit -m "$(cat .git/COMMIT_EDITMSG)"
fi
