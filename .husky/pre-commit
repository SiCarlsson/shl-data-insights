cd web && pnpm exec lint-staged
cd ..

source venv/bin/activate
pre-commit run 
EXIT_CODE=$?

# If pre-commit modified files and re-stages and re-commits
if [ $EXIT_CODE -ne 0 ]; then
    printf "\n\nPre-commit modified files. Staging and re-committing..."
    git add -A
    git commit -m "$(cat .git/COMMIT_EDITMSG)"
fi